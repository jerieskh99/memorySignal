{
  "domain": "Kali Jeries",
  "qemuMonitorSocket": "",
  "ramSizeMb": 2048,
  "imageDir": "/var/lib/libvirt/qemu/dump",
  "outputDir": "/project/homes/jeries/memory_traces/output_dir",
  "rustDeltaCalculationProgram": "/project/homes/jeries/memorySignal/VM_sampler/VM_Capture/live_delta_calc/target/release/live_delta_calc",
  "intervalMsec": 5000,
  "queueDir": "/project/homes/jeries/memory_traces/queue_dir",
  "streaming": {
    "enabled": true,
    "python": "python3",
    "streamingMetricsModule": "coherence_temp_spec_stability.streaming_metrics",
    "streamingOutputDir": "/project/homes/jeries/memory_traces/streaming_results",
    "minFramesForStreaming": 128,
    "deltaMetric": "cosine",
    "projectRoot": "/project/homes/jeries/memorySignal"
  },
  "rawRetention": {
    "enabled": false,
    "keepDumps": 50,
    "rawDir": "/project/homes/jeries/memory_traces/raw_kept",
    "rawMatrixNpy": "/project/homes/jeries/memory_traces/raw_matrix.npy",
    "rawBuild": {
      "enabled": true,
      "builderProgram": "python3 -m coherence_temp_spec_stability.raw_matrix_builder",
      "mode": "mean_byte",
      "pageSize": 4096,
      "maxBytes": 0
    },
    "rawMetrics": {
      "enabled": true,
      "projectRoot": "/project/homes/jeries/memorySignal",
      "validatorModule": "coherence_temp_spec_stability.stability_validator",
      "windowSize": 128,
      "stepSize": 64,
      "outputDir": "/project/homes/jeries/memory_traces/raw_metrics_out"
    }
  },
  "backpressure": {
    "maxPendingJobs": 20,
    "sleepOnBackpressureSeconds": 1
  },
  "vmStatePolling": {
    "pollIntervalMs": 200,
    "timeoutSeconds": 30
  },
  "chownUser": "jeries",
  "chownGroup": "jeries"
}